NODE_ENV=development
PORT=4000
DATABASE_URL=file:./dev.db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the web app. Empty = allow all
# (development only). In production, set to your web app's origin, e.g.
#   CORS_ORIGINS=https://app.universal-healthcare.example
CORS_ORIGINS=

# --- Rate limiting -----------------------------------------------------------
# Per-IP fixed-window limiter applied to all /api/* routes. Disable in tests
# by setting NODE_ENV=test (the limiter becomes a no-op pass-through).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Reverse proxy / observability ------------------------------------------
# Set to true when the API runs behind a load balancer / reverse proxy so that
# req.ip reflects the upstream X-Forwarded-For. Required for accurate rate
# limiting and request logging in production.
TRUST_PROXY=false
LOG_LEVEL=info

# --- Phase 2: refresh tokens, email verification, password reset -------------
# Refresh tokens are one-time-use and rotated on every /api/auth/refresh call.
# A refresh presented twice (theft signal) revokes all refresh tokens for the user.
REFRESH_TOKEN_TTL_DAYS=30
EMAIL_VERIFICATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=60

# Email — ConsoleEmailService logs every message via the structured logger.
# Production deployments should swap in a real provider (SES, Resend, SendGrid).
EMAIL_FROM=noreply@universal-healthcare.local
APP_URL=http://localhost:3000

# --- S3 (optional) -----------------------------------------------------------
# Set AWS_S3_ENDPOINT to point at an S3-compatible store (MinIO, LocalStack,
# Cloudflare R2). Leave empty to use real AWS S3.
AWS_S3_ENDPOINT=

# --- Sentry (optional, no-op when SENTRY_DSN is empty) -----------------------
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
