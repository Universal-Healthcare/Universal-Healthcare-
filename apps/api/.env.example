NODE_ENV=development
PORT=4000
DATABASE_URL=file:./dev.db
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1h

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for the web app. Empty = allow all
# (development only). In production, set to your web app's origin, e.g.
#   CORS_ORIGINS=https://app.universal-healthcare.example
CORS_ORIGINS=

# --- Rate limiting -----------------------------------------------------------
# Per-IP fixed-window limiter applied to all /api/* routes. Disable in tests
# by setting NODE_ENV=test (the limiter becomes a no-op pass-through).
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# --- Reverse proxy / observability ------------------------------------------
# Set to true when the API runs behind a load balancer / reverse proxy so that
# req.ip reflects the upstream X-Forwarded-For. Required for accurate rate
# limiting and request logging in production.
TRUST_PROXY=false
LOG_LEVEL=info
