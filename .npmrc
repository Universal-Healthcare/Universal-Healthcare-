# ─────────────────────────────────────────────────────────────────────────────
# Universal Healthcare — workspace .npmrc
#
# Affects every pnpm install / pnpm run invocation in this repo (and in CI).
# Add a project-level .npmrc in a sub-package to override individual settings.
# ─────────────────────────────────────────────────────────────────────────────

# Reject the install if the local Node or pnpm version doesn't satisfy the
# `engines` field of any package in the workspace. Without this, pnpm just
# warns and proceeds, so a Node 20 vs Node 22 mismatch surfaces at the next
# typecheck instead of at install time.
engine-strict=true

# Auto-install peer dependencies instead of failing with "missing peer dep X".
# pnpm 10 defaults this to true; setting it explicitly here documents the
# intent and protects us if the default ever changes.
auto-install-peers=true
